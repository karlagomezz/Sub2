import java.util.*;
import java.lang.Math;
import java.util.Scanner;

public class Operaciones {
    public static void main(String[] args) {
        int n1, n2, suma;
        double raiz_Cuadrado;
        double cubo;

        Scanner teclado = new Scanner(System.in);

        System.out.println("Programa que suma 2 números y los eleva al cuadrado");

        System.out.println("Escribe el primer numero a sumar:");
        n1 = teclado.nextInt();

        System.out.println("Escribe el segundo numero a sumar:");
        n2 = teclado.nextInt();

        // Sumamos los números
        suma = n1 + n2;

        System.out.println("El resultado de la suma es " + suma);

        // Obtenemos la raíz cuadrada de la suma
        raiz_Cuadrado = Math.sqrt(suma);
        System.out.println("La raíz cuadrada de la suma es " + raiz_Cuadrado);

        // Elevamos la suma al cubo
        cubo = Math.pow(suma, 3);
        System.out.println("La suma al cubo es " + cubo);
    }
}
}
